# ==========================================================
#  Plex Playlist Sync — Configuration
#  ----------------------------------------------------------
#  Copy this file to ".env" (exact name, no ".example") and
#  fill in your own details. Your ".env" file is private and
#  is never uploaded to GitHub.
# ==========================================================

# The port you'll open the app on in your browser (default 8511).
WEB_PORT=8511

# Leave as 0.0.0.0 to allow access from other devices on your
# home network. Set to 127.0.0.1 to restrict to THIS computer only.
HOST=0.0.0.0

# Set to "true" ONLY while troubleshooting. Keep "false" normally
# (leaving debug on is a security risk on a shared network).
FLASK_DEBUG=false

# ----------------------------------------------------------
#  YOUR PLEX SERVERS
#  ----------------------------------------------------------
#  Add one numbered block per server. You need at least ONE
#  server (TWO if you want to sync playlists between them).
#  To add more, copy a block and bump the number (SERVER_3...).
#
#  HOW TO FIND YOUR PLEX TOKEN (X-Plex-Token):
#  https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
#
#  The URL is your server's address + port 32400, for example:
#    http://192.168.1.10:32400   (a server on your local network)
#    http://YOUR-PUBLIC-IP:32400 (a remote server, if exposed)
# ----------------------------------------------------------

PLEX_SERVER_1_NAME=Server 1 (Local)
PLEX_SERVER_1_URL=http://192.168.1.10:32400
PLEX_SERVER_1_TOKEN=your_plex_token_here

PLEX_SERVER_2_NAME=Server 2 (Remote)
PLEX_SERVER_2_URL=http://192.168.1.20:32400
PLEX_SERVER_2_TOKEN=your_plex_token_here

# Optional third server — remove the leading "#" to enable it:
# PLEX_SERVER_3_NAME=Server 3 (Backup)
# PLEX_SERVER_3_URL=http://192.168.1.30:32400
# PLEX_SERVER_3_TOKEN=your_plex_token_here
